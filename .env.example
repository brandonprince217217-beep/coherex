# =============================================================
# Coherex — Environment Variables
# =============================================================
# SETUP:
#   1. Copy this file:   cp .env.example .env.local
#   2. Fill in the real values below (replace everything after =)
#   3. Save .env.local — it is gitignored and will never be committed
#
# Never put real secrets in this file (.env.example is committed).
# =============================================================


# -------------------------------------------------------------
# OPENAI API KEY  (required — the site won't start without it)
# -------------------------------------------------------------
# How to get it:
#   1. Go to https://platform.openai.com/api-keys
#   2. Sign in / create a free account
#   3. Click "Create new secret key", give it a name, click Create
#   4. Copy the key (starts with sk-) — you can only see it once!
# Cost: uses gpt-4o-mini, very cheap (~$0.15 per 1M tokens)
OPENAI_API_KEY=sk-...


# -------------------------------------------------------------
# SUPABASE  (required for database / session features)
# -------------------------------------------------------------
# How to get it:
#   1. Go to https://supabase.com and sign in (free tier works)
#   2. Click "New project" (green button, top right of the dashboard)
#   3. Fill in a name, pick a region, set a database password, click Create project
#   4. Once the project loads, go to Settings → API in the left sidebar
#   5. Copy the two values below from that page

# "Project URL" — looks like https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# "anon / public" key — long string starting with eyJ...
# This key is safe to expose in the browser (it is public by design)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
